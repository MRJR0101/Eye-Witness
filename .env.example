# ============================================================================
#  Eye-Witness Observability — Environment Variables
# ============================================================================
#
#  Copy this file to .env and fill in your values.
#  PowerShell: Copy-Item .env.example .env
#  Bash:       cp .env.example .env
#
# ── New Relic License Key ───────────────────────────────────────────────────
#  Get this from: New Relic → API Keys → INGEST - LICENSE
NEW_RELIC_LICENSE_KEY="YOUR_NR_LICENSE_KEY"

# ── Sentry DSN (optional — empty = SDK disabled / no-op) ───────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ── OpenTelemetry: Service Identity ────────────────────────────────────────
OTEL_SERVICE_NAME="eye-witness"

# ── OpenTelemetry: OTLP Export to New Relic ────────────────────────────────
#  Endpoint: https://otlp.nr-data.net (US datacenter)
#            https://otlp.eu01.nr-data.net (EU datacenter)
#  Protocol: http/protobuf (recommended by New Relic)
#  Header:   api-key=<license-key> (required on every OTLP request)
#  TLS 1.2 is required; HTTPS handles this automatically.
OTEL_EXPORTER_OTLP_ENDPOINT="https://otlp.nr-data.net"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_OTLP_HEADERS="api-key=${NEW_RELIC_LICENSE_KEY}"

# ── OpenTelemetry: Exporter Selection ──────────────────────────────────────
#  Start with traces only. Enable metrics/logs when ready.
OTEL_TRACES_EXPORTER="otlp"
OTEL_METRICS_EXPORTER="none"
OTEL_LOGS_EXPORTER="none"

# ── OpenTelemetry: Sampling ────────────────────────────────────────────────
#  always_on  = capture every trace (dev/debugging)
#  traceidratio = sample a fraction (production)
#  always_off = disable tracing
OTEL_TRACES_SAMPLER="always_on"

# ── OpenTelemetry: Resource Attributes ─────────────────────────────────────
OTEL_RESOURCE_ATTRIBUTES="service.name=${OTEL_SERVICE_NAME},deployment.environment=dev"

# ── OpenTelemetry: Logging Level ───────────────────────────────────────────
#  Set to "debug" for troubleshooting OTel itself, "info" for normal use.
OTEL_PYTHON_LOGGING_LEVEL="info"

# ── OpenTelemetry: BatchSpanProcessor Tuning ───────────────────────────────
#  Uncomment to override defaults:
# OTEL_BSP_SCHEDULE_DELAY=5000
# OTEL_BSP_MAX_QUEUE_SIZE=2048
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
# OTEL_BSP_EXPORT_TIMEOUT=30000
